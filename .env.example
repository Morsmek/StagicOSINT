# OGI Backend Configuration Example
# Copy this to .env and fill in your values

# Core Application
APP_NAME=OGI - Open Graph Intelligence
APP_VERSION=1.0.0
DEBUG=False

# Database
DATABASE_URL=sqlite+aiosqlite:///./ogi.db

# API Configuration
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# External API Keys (Optional - only needed for specific transforms)
SHODAN_API_KEY=
VIRUSTOTAL_API_KEY=
IPINFO_TOKEN=
HUNTER_API_KEY=
PROSPEO_API_KEY=
OPENCAGE_API_KEY=

# AI Features (Optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
